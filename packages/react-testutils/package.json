{
  "name": "@penguintechinc/react-testutils",
  "version": "0.1.1",
  "description": "Shared Vitest + RTL test utilities for PenguinTech React packages",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./setup": "./src/setup.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "echo 'nothing to clean'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck"
  },
  "keywords": [
    "penguintech",
    "testing",
    "vitest",
    "react-testing-library",
    "test-utils"
  ],
  "author": "Penguin Tech Inc <dev@penguintech.io>",
  "license": "AGPL-3.0",
  "homepage": "https://www.penguintech.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/penguintechinc/penguin-libs.git",
    "directory": "packages/react-testutils"
  },
  "bugs": {
    "url": "https://github.com/penguintechinc/penguin-libs/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "@testing-library/react": ">=14",
    "@testing-library/jest-dom": ">=6",
    "vitest": ">=1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.2.0",
    "jsdom": "28.0.0",
    "react": "*",
    "react-dom": "*",
    "typescript": "5.3.3",
    "vitest": "4.0.18"
  }
}
