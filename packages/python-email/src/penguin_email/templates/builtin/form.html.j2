{% extends "base.html.j2" %}
{% block title %}{{ title | default('Form Submission') }}{% endblock %}
{% block content %}
<p><strong>{{ title | default('Form Submission') }}</strong></p>
{% if data is defined and data %}
<table class="table-wrap">
  <tbody>
    {% for key, value in data.items() %}
    <tr>
      <td style="font-weight:600;width:40%;color:#0f172a;">{{ key }}</td>
      <td>{{ value }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
{% endblock %}
